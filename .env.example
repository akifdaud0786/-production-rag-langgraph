# --- LLM Gateway (Groq) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=20

# --- Vector backend: "qdrant" for local/dev, "vertex" for GCP production ---
VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_documents

# --- Vertex AI Vector Search (production) ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
VERTEX_INDEX_ENDPOINT_ID=
VERTEX_DEPLOYED_INDEX_ID=

# --- GCS buckets ---
GCS_RAW_BUCKET=your-project-rag-raw
GCS_PROCESSED_BUCKET=your-project-rag-processed

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Re-ranking ---
RERANKER_MODEL=ms-marco-MiniLM-L-12-v2
RERANK_TOP_K=5
RERANK_MIN_SCORE=0.35

# --- Agentic core ---
MAX_REFINE_ITERATIONS=2
CRITIQUE_MODEL=llama-3.1-8b-instant

# --- Guardrails ---
GUARDRAILS_ENABLED=true
PII_REDACTION_ENABLED=true

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501

# --- Observability ---
LOGFIRE_TOKEN=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=production-rag-langgraph

# --- Firestore (metadata store) ---
FIRESTORE_COLLECTION=document_metadata
